# Top announcement bar (AnnouncementBar)
# Set ANNOUNCEMENT_ENABLED=false to hide the bar entirely.
ANNOUNCEMENT_ENABLED=true
ANNOUNCEMENT_MESSAGE=""
ANNOUNCEMENT_HREF=#seeit
# Optional badge label (defaults to "New" from home content)
# ANNOUNCEMENT_LABEL=New

# Lighter motion on viewports ≤900px (marquees off, static particles, no GSAP scroll reveals)
NEXT_PUBLIC_REDUCE_MOTION_ON_MOBILE=true
